/**
 * tour.js — 新手導覽 Onboarding Tour
 * 首次開啟自動啟動；可從設定頁面重新播放。
 * Zero-dependency，使用 box-shadow spotlight + fixed bubble。
 */

const Tour = (() => {
  const LS_KEY  = 'md_tour_seen';
  const VERSION = '1';

  const DESKTOP_STEPS = [
    { target: '.nav-logo',       titleKey: 'tour.s1.title',  descKey: 'tour.s1.desc'  },
    { target: '#btn-new',        titleKey: 'tour.s2.title',  descKey: 'tour.s2.desc'  },
    { target: '#tabs-bar',       titleKey: 'tour.s3.title',  descKey: 'tour.s3.desc'  },
    { target: '#editor-pane',    titleKey: 'tour.s4.title',  descKey: 'tour.s4.desc'  },
    { target: '#preview-pane',   titleKey: 'tour.s5.title',  descKey: 'tour.s5.desc'  },
    { target: '.editor-toolbar', titleKey: 'tour.s6.title',  descKey: 'tour.s6.desc'  },
    { target: '#btn-cloud',      titleKey: 'tour.s7.title',  descKey: 'tour.s7.desc'  },
    { target: '#btn-typo',       titleKey: 'tour.s8.title',  descKey: 'tour.s8.desc'  },
    { target: '.status-bar',     titleKey: 'tour.s9.title',  descKey: 'tour.s9.desc'  },
    { target: '.status-bar', pulseTarget: '#btn-outline', titleKey: 'tour.s10.title', descKey: 'tour.s10.desc' },
  ];

  const MOBILE_STEPS = [
    { target: '.navbar',          titleKey: 'tour.s1.title',  descKey: 'tour.s1.desc'   },
    { target: '.mode-toggle',     titleKey: 'tour.s2m.title', descKey: 'tour.s2m.desc'  },
    { target: '#editor-pane',     titleKey: 'tour.s4.title',  descKey: 'tour.s4m.desc'  },
    { target: '#bottom-toolbar',  titleKey: 'tour.s6m.title', descKey: 'tour.s6m.desc'  },
    { target: '.status-bar',      titleKey: 'tour.s9.title',  descKey: 'tour.s9.desc'   },
    { target: '.status-bar', pulseTarget: '#btn-outline', titleKey: 'tour.s10.title', descKey: 'tour.s10.desc' },
    { target: '#btn-mobile-menu', titleKey: 'tour.s10m.title',descKey: 'tour.s10m.desc' },
  ];

  let _steps   = [];
  let _current = 0;

  function _isMobile() { return window.innerWidth < 768; }
  function _el(id) { return document.getElementById(id); }

  // ---- spotlight: div positioned over target with huge box-shadow ----
  function _updateSpotlight(targetEl) {
    const spot = _el('tour-spotlight');
    if (!spot) return;
    if (!targetEl) {
      spot.style.opacity = '0';
      return;
    }
    const PAD  = 6;
    const rect = targetEl.getBoundingClientRect();
    spot.style.top    = (rect.top    - PAD) + 'px';
    spot.style.left   = (rect.left   - PAD) + 'px';
    spot.style.width  = (rect.width  + PAD * 2) + 'px';
    spot.style.height = (rect.height + PAD * 2) + 'px';
    spot.style.opacity = '1';
  }

  // ---- bubble auto-positioning ----
  function _positionBubble(targetEl) {
    const bubble = _el('tour-bubble');
    if (!bubble) return;

    // Mobile: always anchor to bottom of screen (above bottom toolbar)
    if (_isMobile()) {
      bubble.style.cssText = 'position:fixed;bottom:100px;left:12px;right:12px;top:auto;transform:none;';
      return;
    }

    if (!targetEl) {
      bubble.style.cssText = 'position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);';
      return;
    }

    bubble.style.cssText = 'position:fixed;';
    const rect = targetEl.getBoundingClientRect();
    const bw   = bubble.offsetWidth  || 300;
    const bh   = bubble.offsetHeight || 170;
    const vw   = window.innerWidth;
    const vh   = window.innerHeight;
    const GAP  = 14;
    let top, left;

    if (rect.bottom + GAP + bh < vh) {
      top  = rect.bottom + GAP;
      left = rect.left + rect.width / 2 - bw / 2;
    } else if (rect.top - GAP - bh > 0) {
      top  = rect.top - GAP - bh;
      left = rect.left + rect.width / 2 - bw / 2;
    } else if (rect.right + GAP + bw < vw) {
      top  = rect.top + rect.height / 2 - bh / 2;
      left = rect.right + GAP;
    } else {
      top  = rect.top + rect.height / 2 - bh / 2;
      left = rect.left - GAP - bw;
    }

    left = Math.max(8, Math.min(vw - bw - 8, left));
    top  = Math.max(8, Math.min(vh - bh - 8, top));
    bubble.style.top  = top  + 'px';
    bubble.style.left = left + 'px';
  }

  // ---- render one step ----
  function _showStep(index) {
    _current = index;
    const step     = _steps[index];
    const total    = _steps.length;
    const targetEl = document.querySelector(step.target);

    _updateSpotlight(targetEl);

    // Pulse highlight for small targets that need extra attention
    document.querySelectorAll('.tour-pulse-highlight').forEach(el => el.classList.remove('tour-pulse-highlight'));
    if (step.pulseTarget) {
      const pEl = document.querySelector(step.pulseTarget);
      if (pEl) pEl.classList.add('tour-pulse-highlight');
    }

    const titleEl    = _el('tour-title');
    const descEl     = _el('tour-desc');
    const progressEl = _el('tour-progress');
    const prevBtn    = _el('tour-prev');
    const nextBtn    = _el('tour-next');
    const skipBtn    = _el('tour-skip');

    if (titleEl)    titleEl.textContent    = I18n.t(step.titleKey);
    if (descEl)     descEl.textContent     = I18n.t(step.descKey);
    if (progressEl) progressEl.textContent = `${index + 1} / ${total}`;
    if (prevBtn) {
      prevBtn.textContent      = I18n.t('tour.prev');
      prevBtn.style.visibility = index === 0 ? 'hidden' : 'visible';
    }
    if (nextBtn) nextBtn.textContent = index === total - 1 ? I18n.t('tour.done') : I18n.t('tour.next');
    if (skipBtn) skipBtn.textContent = I18n.t('tour.skip');

    const bubble = _el('tour-bubble');
    if (bubble) {
      bubble.removeAttribute('hidden');
      requestAnimationFrame(() => _positionBubble(targetEl));
    }
  }

  function next() {
    if (_current >= _steps.length - 1) { finish(); return; }
    _showStep(_current + 1);
  }

  function prev() {
    if (_current <= 0) return;
    _showStep(_current - 1);
  }

  function finish() {
    localStorage.setItem(LS_KEY, VERSION);
    _el('tour-overlay')?.setAttribute('hidden', '');
    const spot = _el('tour-spotlight');
    if (spot) spot.style.opacity = '0';
    _el('tour-bubble')?.setAttribute('hidden', '');
    _el('tour-welcome')?.setAttribute('hidden', '');
    document.querySelectorAll('.tour-pulse-highlight').forEach(el => el.classList.remove('tour-pulse-highlight'));
  }

  function start() {
    _steps   = _isMobile() ? MOBILE_STEPS : DESKTOP_STEPS;
    _current = 0;
    _el('tour-welcome')?.setAttribute('hidden', '');
    _el('tour-overlay')?.removeAttribute('hidden');
    _showStep(0);
  }

  function replay() {
    localStorage.removeItem(LS_KEY);
    start();
  }

  function _showWelcome() {
    const overlay  = _el('tour-overlay');
    const welcome  = _el('tour-welcome');
    if (!welcome) return;
    if (overlay) overlay.removeAttribute('hidden');
    welcome.removeAttribute('hidden');

    const titleEl  = _el('tour-welcome-title');
    const descEl   = _el('tour-welcome-desc');
    const startBtn = _el('tour-welcome-start');
    const skipBtn  = _el('tour-welcome-skip');
    if (titleEl)  titleEl.textContent  = I18n.t('tour.welcome.title');
    if (descEl)   descEl.textContent   = I18n.t('tour.welcome.desc');
    if (startBtn) startBtn.textContent = I18n.t('tour.welcome.start');
    if (skipBtn)  skipBtn.textContent  = I18n.t('tour.welcome.skip');
  }

  function init() {
    _el('tour-skip')?.addEventListener('click', finish);
    _el('tour-prev')?.addEventListener('click', prev);
    _el('tour-next')?.addEventListener('click', next);
    _el('tour-welcome-start')?.addEventListener('click', start);
    _el('tour-welcome-skip')?.addEventListener('click', () => {
      localStorage.setItem(LS_KEY, VERSION);
      _el('tour-overlay')?.setAttribute('hidden', '');
      _el('tour-welcome')?.setAttribute('hidden', '');
    });
    _el('btn-tour-replay')?.addEventListener('click', () => {
      // Close settings modal first, then replay
      document.getElementById('settings-modal')?.setAttribute('hidden', '');
      setTimeout(replay, 200);
    });

    // Auto-start on first visit (after i18n + layout are ready)
    if (!localStorage.getItem(LS_KEY)) {
      setTimeout(_showWelcome, 700);
    }
  }

  return { init, start, replay, finish };
})();
